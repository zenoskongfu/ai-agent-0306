{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "allowJs": true,
    "moduleResolution": "nodenext",
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/project"
  ]
}